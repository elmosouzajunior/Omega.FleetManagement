{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://YOUR_FRONTEND_DOMAIN"
    ]
  },
  "StorageConfig": {
    "Provider": "AzureBlob",
    "AzureBlob": {
      "ConnectionString": "USE_APP_SETTING__StorageConfig__AzureBlob__ConnectionString",
      "ContainerName": "omega-fleet-files"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "USE_APP_SETTING__ConnectionStrings__DefaultConnection"
  },
  "Jwt": {
    "Key": "USE_APP_SETTING__Jwt__Key",
    "Issuer": "OmegaFleetAPI",
    "Audience": "OmegaFleetAngularApp",
    "DurationInMinutes": 480
  }
}
