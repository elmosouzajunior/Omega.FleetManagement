{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "StorageConfig": {
    "Provider": "Local",
    "BasePath": "C:\\OmegaStorage\\Viagens",
    "AzureBlob": {
      "ConnectionString": "",
      "ContainerName": "omega-fleet-files"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "USE_ENV_OR_USER_SECRETS__ConnectionStrings__DefaultConnection"
  },
  "Jwt": {
      "Key": "USE_ENV_OR_USER_SECRETS__Jwt__Key",
      "Issuer": "OmegaFleetAPI",
      "Audience": "OmegaFleetAngularApp",
      "DurationInMinutes": 480
  }
}

